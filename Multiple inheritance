#include <iostream>
using namespace std;

// First base class
class A {
public:
    void showA() {
        cout << "This is class A" << endl;
    }
};

// Second base class
class B {
public:
    void showB() {
        cout << "This is class B" << endl;
    }
};

// Derived class inheriting from A and B
class C : public A, public B {
public:
    void showC() {
        cout << "This is class C" << endl;
    }
};

int main() {
    C obj;

    obj.showA(); // from class A
    obj.showB(); // from class B
    obj.showC(); // from class C

    return 0;
}
