#include <iostream>
using namespace std;

// Base class
class Base {
public:
    Base() {
        cout << "Base Constructor" << endl;
    }

    // Virtual function (for dynamic binding)
    virtual void show() {
        cout << "Base show function" << endl;
    }

    // Virtual Destructor
    virtual ~Base() {
        cout << "Base Destructor" << endl;
    }
};

// Derived class
class Derived : public Base {
public:
    Derived() {
        cout << "Derived Constructor" << endl;
    }

    void show() override {
        cout << "Derived show function" << endl;
    }

    ~Derived() {
        cout << "Derived Destructor" << endl;
    }
};

int main() {
    Base* b;

    // Dynamic memory allocation
    b = new Derived();

    // Dynamic binding (calls Derived's show)
    b->show();

    // Proper deletion (calls both destructors)
    delete b;

    return 0;
}
